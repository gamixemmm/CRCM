generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id                 String        @id @default(cuid())
  companyId          String?
  brand              String
  model              String
  year               Int
  plateNumber        String
  color              String        @default("Black")
  transmission       String        @default("Automatic")
  fuelType           String        @default("Gasoline")
  dailyRate          Float
  mileage            Int           @default(0)
  status             String        @default("AVAILABLE")
  imageUrl           String?
  circulationDate    DateTime?
  insuranceExpiry    DateTime?
  registrationExpiry DateTime?
  technicalInspectionDueDate DateTime?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  bookings           Booking[]
  maintenance        Maintenance[]
  expenses           Expense[]
  technicalInspections TechnicalInspection[]
  vignettePayments   VignettePayment[]
  insurancePayments   InsurancePayment[]

  company            Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, plateNumber])
}

model Customer {
  id            String    @id @default(cuid())
  companyId     String?
  firstName     String
  lastName      String
  phone         String?
  email         String?
  licenseNumber String?   @unique
  licenseExpiry DateTime?
  address       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings      Booking[]

  company       Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, licenseNumber])
}

model Booking {
  id              String   @id @default(cuid())
  companyId       String?
  customerId      String
  vehicleId       String
  startDate       DateTime
  endDate         DateTime
  pickupLocation  String?
  returnLocation  String?
  status          String   @default("CONFIRMED")
  totalAmount     Float
  depositAmount   Float    @default(0)
  pricePerDay     Float?
  clientType      String   @default("PARTICULIER")
  companyName     String?
  companyICE      String?
  paymentMethod   String   @default("ESPECE")
  driverFirstName String?
  driverLastName  String?
  driverCIN       String?
  driverLicense   String?
  driver2FirstName String?
  driver2LastName  String?
  driver2CIN       String?
  driver2License   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer @relation(fields: [customerId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  invoice         Invoice?

  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String   @id @default(cuid())
  companyId       String?
  bookingId       String   @unique
  subtotal        Float
  extraCharges    Float    @default(0)
  extraChargeDesc String?
  discount        Float    @default(0)
  totalAmount     Float
  depositPaid     Float    @default(0)
  amountDue       Float
  paymentStatus   String   @default("PENDING")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  booking         Booking  @relation(fields: [bookingId], references: [id])

  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Maintenance {
  id              String    @id @default(cuid())
  companyId       String?
  vehicleId       String
  serviceDate     DateTime
  returnDate      DateTime?
  description     String
  cost            Float     @default(0)
  serviceProvider String?
  notes           String?
  type            String    @default("Autre")
  partsUsed       String[]  @default([])
  mileageAtService Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])

  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  companyId   String?
  date        DateTime @default(now())
  category    String
  amount      Float
  description String?
  vehicleId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])

  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?
  actorId     String?
  actorName   String?
  actorEmail  String?
  actorRole   String?
  action      String
  entityType  String?
  entityId    String?
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@index([companyId, actorId])
}

model TechnicalInspection {
  id             String   @id @default(cuid())
  companyId      String?
  vehicleId      String
  inspectionDate DateTime @default(now())
  nextDueDate    DateTime
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  company        Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model VignettePayment {
  id        String   @id @default(cuid())
  companyId String?
  vehicleId String
  year      Int
  paidAt    DateTime @default(now())
  amount    Float    @default(0)
  expenseId String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, vehicleId, year])
}

model InsurancePayment {
  id        String   @id @default(cuid())
  companyId String?
  vehicleId String
  paidAt    DateTime @default(now())
  endDate   DateTime
  amount    Float    @default(0)
  expenseId String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Employee {
  id             String                  @id @default(cuid())
  companyId      String?
  firstName      String
  lastName       String
  phone          String?
  email          String?
  role           String?
  hasSalary      Boolean                 @default(true)
  salary         Float?
  payDay         Int?
  active         Boolean                 @default(true)
  notes          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  salaryPayments EmployeeSalaryPayment[]
  account        EmployeeAccount?

  company        Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model EmployeeRole {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
}

model EmployeeSalaryPayment {
  id         String   @id @default(cuid())
  companyId  String?
  employeeId String
  month      Int
  year       Int
  amount     Float
  status     String   @default("PENDING")
  paidAt     DateTime?
  expenseId  String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, month, year])
}

model GlobalSettings {
  id            String @id @default("global")
  companyId     String?
  cashRegister  Float  @default(0)

  company       Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
}

model Company {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  contactEmail String?
  active       Boolean   @default(true)
  disabledAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  admin             CompanyAdmin?
  employeeAccounts  EmployeeAccount[]
  vehicles          Vehicle[]
  customers         Customer[]
  bookings          Booking[]
  invoices          Invoice[]
  maintenance       Maintenance[]
  expenses          Expense[]
  technicalInspections TechnicalInspection[]
  vignettePayments  VignettePayment[]
  insurancePayments InsurancePayment[]
  employees         Employee[]
  employeeRoles     EmployeeRole[]
  salaryPayments    EmployeeSalaryPayment[]
  globalSettings    GlobalSettings[]
  auditLogs         AuditLog[]
}

model CompanyAdmin {
  id           String   @id @default(cuid())
  companyId    String   @unique
  name         String
  email        String   @unique
  passwordHash String
  preferredCurrency String @default("MAD")
  preferredLanguage String @default("en")
  active       Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model EmployeeAccount {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String   @unique
  name         String
  email        String   @unique
  passwordHash String
  preferredCurrency String @default("MAD")
  preferredLanguage String @default("en")
  active       Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
