generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id                 String        @id @default(cuid())
  brand              String
  model              String
  year               Int
  plateNumber        String        @unique
  color              String        @default("Black")
  transmission       String        @default("Automatic")
  fuelType           String        @default("Gasoline")
  dailyRate          Float
  mileage            Int           @default(0)
  status             String        @default("AVAILABLE")
  imageUrl           String?
  circulationDate    DateTime?
  insuranceExpiry    DateTime?
  registrationExpiry DateTime?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  bookings           Booking[]
  maintenance        Maintenance[]
}

model Customer {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  phone         String?
  email         String?
  licenseNumber String?   @unique
  licenseExpiry DateTime?
  address       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings      Booking[]
}

model Booking {
  id              String   @id @default(cuid())
  customerId      String
  vehicleId       String
  startDate       DateTime
  endDate         DateTime
  pickupLocation  String?
  returnLocation  String?
  status          String   @default("CONFIRMED")
  totalAmount     Float
  depositAmount   Float    @default(0)
  pricePerDay     Float?
  clientType      String   @default("PARTICULIER")
  companyName     String?
  companyICE      String?
  paymentMethod   String   @default("ESPECE")
  driverFirstName String?
  driverLastName  String?
  driverCIN       String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer @relation(fields: [customerId], references: [id])
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  invoice         Invoice?
}

model Invoice {
  id              String   @id @default(cuid())
  bookingId       String   @unique
  subtotal        Float
  extraCharges    Float    @default(0)
  extraChargeDesc String?
  discount        Float    @default(0)
  totalAmount     Float
  depositPaid     Float    @default(0)
  amountDue       Float
  paymentStatus   String   @default("PENDING")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  booking         Booking  @relation(fields: [bookingId], references: [id])
}

model Maintenance {
  id              String    @id @default(cuid())
  vehicleId       String
  serviceDate     DateTime
  returnDate      DateTime?
  description     String
  cost            Float     @default(0)
  serviceProvider String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
}
